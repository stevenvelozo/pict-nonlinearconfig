{
    "name": "pict-nonlinearconfig",
    "version": "1.0.0",
    "description": "Pict Nonlinear Configuration Manager",
    "main": "source/Pict-Application-NonlinearConfig.js",
    "scripts": {
        "start": "node source/Pict-Application-NonlinearConfig.js",
        "build": "npx quack build && npx quack copy",
        "test": "echo \"Error: no test specified\" && exit 0"
    },
    "author": "steven velozo <steven@velozo.com>",
    "license": "MIT",
    "dependencies": {
        "pict": "^1.0.368",
        "pict-application": "^1.0.34",
        "pict-provider": "^1.0.13",
        "pict-router": "^1.0.10",
        "pict-view": "^1.0.68"
    },
    "devDependencies": {
        "pict-docuserve": "^1.3.0",
        "quackage": "^1.2.3"
    },
    "copyFilesSettings": {
        "whenFileExists": "overwrite"
    },
    "copyFiles": [
        {
            "from": "./html/*",
            "to": "./dist/"
        },
        {
            "from": "./css/**",
            "to": "./dist/css/"
        },
        {
            "from": "./node_modules/pict/dist/*",
            "to": "./dist/js/"
        }
    ]
}
